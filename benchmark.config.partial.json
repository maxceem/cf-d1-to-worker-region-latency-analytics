{
  "d1DatabaseNamePrefix": "d1-placement-bench-partial-db",
  "deleteD1DatabasesAfterRun": true,
  "workerNamePrefix": "d1-placement-bench-partial",
  "workerCompatibilityDate": "2026-06-17",
  "workerCompatibilityFlags": [
    "nodejs_compat"
  ],
  "workerObservabilityEnabled": true,
  "workerRequestsPer24Hours": 80000,
  "databaseDiscoveryAttemptsPerRegion": 50,
  "workerPlacementsByD1Location": {
    "enam": [
      "aws:us-east-1",
      "gcp:us-east4",
      "azure:eastus2"
    ],
    "oc": [
      "aws:ap-southeast-2",
      "gcp:australia-southeast1",
      "azure:australiaeast"
    ]
  },
  "maxWorkersPerBatch": 3,
  "benchmark": {
    "warmupRequests": 3,
    "measuredRequests": 100,
    "splitInRounds": 5,
    "minSuccessfulRequests": 3,
    "queriesPerRequest": 3,
    "requestTimeoutMs": 30000
  },
  "cleanupWorkers": true,
  "propagationSeconds": 10,
  "resultsDir": "results-partial",
  "siteOutputPath": "docs/index.html",
  "openSiteAfterRun": true
}
