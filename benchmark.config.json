{
  "d1DatabaseNamePrefix": "d1-placement-bench-db",
  "deleteD1DatabasesAfterRun": true,
  "workerNamePrefix": "d1-placement-bench",
  "workerCompatibilityDate": "2026-06-17",
  "workerCompatibilityFlags": [
    "nodejs_compat"
  ],
  "workerObservabilityEnabled": true,
  "maxWorkersPerBatch": 50,
  "benchmark": {
    "warmupRequests": 3,
    "measuredRequests": 100,
    "splitInRounds": 5,
    "minSuccessfulRequests": 5,
    "queriesPerRequest": 5,
    "requestTimeoutMs": 30000
  },
  "cleanupWorkers": true,
  "propagationSeconds": 20,
  "resultsDir": "results",
  "siteOutputPath": "docs/index.html",
  "openSiteAfterRun": true
}
